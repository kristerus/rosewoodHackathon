# Anthropic (existing) — voice-to-ticket, guest brief, predictions
ANTHROPIC_API_KEY=sk-ant-api03-PASTE_YOUR_KEY_HERE

# Tavily (existing, optional) — image search in Guest Profiles
TAVILY_API_KEY=tvly-<your-key-from-tavily.com>

# Supabase (NEW) — Postgres + Realtime for cross-container push.
# Without these the dashboard shows "Offline" and tickets do not persist.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                  # browser-safe (public)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                      # server-only — DO NOT expose

# Resend (NEW, optional) — sends department emails on every ticket.
# When absent we log the would-have-been email to the server console.
RESEND_API_KEY=re_...
